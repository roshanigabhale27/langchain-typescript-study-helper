{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],

    "rootDir": "./src",
    "outDir": "./dist",

    "ignoreDeprecations": "6.0"
  },

  "include": ["src/**/*"]
}